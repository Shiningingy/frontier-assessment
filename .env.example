# Copy to .env and fill in. .env is git-ignored; never commit real keys.

# Required only if config.yaml -> llm.backend is "anthropic".
# The tester can drop their key here to enable the profile-author / reporter / LLM-fallback tiers.
ANTHROPIC_API_KEY=

# Optional model overrides (otherwise taken from config.yaml).
