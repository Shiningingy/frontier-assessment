{
  "site": "books.toscrape.com",
  "template": "catalog-listing",
  "cardinality": "many",
  "match": {
    "url_glob": "/catalogue/*"
  },
  "item_selector": "article.product_pod",
  "discovery": {
    "product_link": "h3 a",
    "next_page": "li.next a"
  },
  "fields": {
    "name": {
      "source": "css",
      "selector": "h3 a",
      "attr": "@title"
    },
    "price": {
      "source": "css",
      "selector": "p.price_color"
    },
    "availability": {
      "source": "css",
      "selector": "p.availability"
    },
    "image_urls": {
      "source": "css",
      "selector": ".image_container img",
      "attr": "@src"
    },
    "product_url": {
      "source": "css",
      "selector": "h3 a",
      "attr": "@href"
    }
  },
