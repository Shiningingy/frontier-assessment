{
  "site": "safcodental.com",
  "template": "product-detail",
  "cardinality": "one",
  "match": {
    "url_glob": "/product/*",
    "signals": [
      "jsonld:Product"
    ]
  },
  "fields": {
    "name": {
      "source": "jsonld",
      "path": "Product.name"
    },
    "sku": {
      "source": "jsonld",
      "path": "Product.sku"
    },
    "brand": {
      "source": "jsonld",
      "path": "Product.brand.name"
    },
    "price": {
      "source": "jsonld",
      "path": "Product.offers.price"
    },
    "currency": {
      "source": "jsonld",
      "path": "Product.offers.priceCurrency"
    },
    "availability": {
      "source": "jsonld",
      "path": "Product.offers.availability"
    },
    "image_urls": {
      "source": "jsonld",
      "path": "Product.image"
    },
    "description": {
      "source": "jsonld",
      "path": "Product.description"
    },
    "product_url": {
      "source": "jsonld",
      "path": "Product.url"
    },
    "specifications": {
      "source": "css",
      "selector": "li",
      "label": "strong",
      "require_colon": true,
      "_note": "Spec rows render as <li><strong>Label:</strong> value</li>; require_colon filters out benefit bullets."
    },
    "alternatives": {
      "source": "css",
      "selector": "a.product-item-link",
      "fields": {
        "name": "@text",
        "url": "@href"
      }
    }
  },
